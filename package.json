	"packageManager": "pnpm@10.24.0",
	"devDependencies": {
		"@types/node": "^25.6.2",
		"@typescript/native-preview": "7.0.0-dev.20260509.2",
		"bumpp": "^11.1.0",
		"knip": "^6.20.0",
		"prettier": "^3.8.4",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
