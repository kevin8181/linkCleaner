{
	"name": "clean-links",
	"type": "module",
	"version": "0.0.4",
	"author": "kevin8181",
	"license": "AGPL-3.0-only",
	"homepage": "https://github.com/kevin8181/linkCleaner#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kevin8181/linkCleaner.git"
	},
	"bugs": {
		"url": "https://github.com/kevin8181/linkCleaner/issues"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "vitest",
